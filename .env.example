# Runtime environment: development | test | production
NODE_ENV=development
# Port the Next.js server listens on (dev + start)
PORT=3000
# Display name surfaced in the UI (HeroSection, metadata)
NEXT_PUBLIC_APP_NAME=Miles Mechanical
# Public origin used for absolute links and metadata.
# REQUIRED in production: set to the real public origin (no trailing slash),
# e.g. https://www.milesmechanicalac.com — otherwise every canonical, Open
# Graph, sitemap, and JSON-LD URL is wrong. The production build hard-fails if
# this is left at localhost (see readAppUrl in src/config/env.ts).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for the apiClient (ky); use a full URL for an external API
NEXT_PUBLIC_API_BASE_URL=/api
# Hosted form-service endpoint for the lead form (e.g. Formspree / Web3Forms).
# When set, LeadForm POSTs submissions here; unset falls back to a client-side
# confirmation (Phase 1 — no owned backend). Public by design (not a secret).
NEXT_PUBLIC_FORM_ENDPOINT=
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). When set, GA4 loads and
# conversion events fire (click-to-call, generate_lead). Unset = analytics is a
# no-op, so the site runs cleanly before the owner provides a property (NFR-6).
NEXT_PUBLIC_GA_ID=
